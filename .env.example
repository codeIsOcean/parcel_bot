# === Telegram Bot ===
BOT_TOKEN=your_bot_token_here
BOT_WEBHOOK_URL=https://fly.kazakhindubai.com/webhook

# === Database ===
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/parcel_bot
# Для dev-режима можно SQLite:
# DATABASE_URL=sqlite+aiosqlite:///./parcel_bot.db

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === FastAPI Backend ===
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=your_secret_key_for_jwt
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === WebApp ===
VITE_API_URL=/api/v1
WEBAPP_URL=https://fly.kazakhindubai.com

# === Docker Production ===
POSTGRES_PASSWORD=your_strong_password_here
GITHUB_REPO=your_username/parcel_bot

# === TON Payments ===
TON_WALLET_ADDRESS=your_ton_wallet
TON_API_KEY=your_ton_api_key

# === Subscription Prices (USD) ===
SUBSCRIPTION_MONTHLY_PRICE=40
SUBSCRIPTION_QUARTERLY_PRICE=100
SUBSCRIPTION_YEARLY_PRICE=300

# === Logging ===
LOG_LEVEL=INFO
